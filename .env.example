# Servidor
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# SIFEN
SIFEN_AMBIENTE=test                    # test | produccion

# Certificado global (opcional si todos los tenants tienen cert en DB)
# Para un solo tenant: configurar aquí. Para multi-tenant: subir via POST /v1/admin/tenants/:id/cert
SIFEN_CERT_PATH=/certs/cert.p12        # Path al certificado PKCS#12
SIFEN_CERT_PASS=tu_passphrase_aqui     # Passphrase del certificado

# Base de datos
DATABASE_URL=postgresql://sifen:CHANGE_ME@localhost:5433/sifen_api

# Redis (BullMQ) — opcional: solo requerido para lotes asíncronos y webhooks encolados
# Sin REDIS_URL el servidor arranca y los endpoints síncronos (documentos, eventos, consultas) funcionan normalmente.
# POST /v1/lotes retorna 503 si REDIS_URL no está configurado.
# REDIS_URL=redis://localhost:6380

# Seguridad — generar con: openssl rand -hex 32
API_KEY_SECRET=genera-un-secreto-de-al-menos-32-caracteres-aqui

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Storage para KuDE PDFs (default: local)
STORAGE_PROVIDER=local                # local | s3
STORAGE_LOCAL_DIR=./storage/kude     # solo si STORAGE_PROVIDER=local

# S3 / MinIO / Cloudflare R2 (solo si STORAGE_PROVIDER=s3)
# S3_BUCKET=sifen-kude
# S3_REGION=us-east-1
# S3_ENDPOINT=http://minio:9000       # omitir para AWS S3 real
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin

# Métricas Prometheus (expone /metrics)
METRICS_ENABLED=false

# Tests E2E contra SIFEN homologación (opcional)
# SIFEN_E2E_CERT_PATH=/path/to/cert.p12
# SIFEN_E2E_CERT_PASS=passphrase
# SIFEN_E2E_RUC=80069563
# SIFEN_E2E_TIMBRADO=12345678
