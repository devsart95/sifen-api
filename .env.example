# Servidor
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# SIFEN
SIFEN_AMBIENTE=test                    # test | produccion
SIFEN_CERT_PATH=/certs/cert.p12        # Path al certificado PKCS#12 del contribuyente
SIFEN_CERT_PASS=tu_passphrase_aqui     # Passphrase del certificado

# Base de datos
DATABASE_URL=postgresql://sifen:CHANGE_ME@localhost:5433/sifen_api

# Redis (BullMQ)
REDIS_URL=redis://localhost:6380

# Seguridad — mínimo 32 caracteres, generar con: openssl rand -hex 32
API_KEY_SECRET=genera-un-secreto-de-al-menos-32-caracteres-aqui

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
