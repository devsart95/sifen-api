generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant ──────────────────────────────────────────────────────────────

model Tenant {
  id            String   @id @default(cuid())
  nombre        String
  ruc           String   @unique
  dvRuc         String   @map("dv_ruc")
  activo        Boolean  @default(true)
  rateLimitMax  Int?     @map("rate_limit_max")

  // Certificado PKCS#12 encriptado (AES-256-GCM, key derivada via HKDF por tenant)
  certEncriptado     Bytes?    @map("cert_encriptado")       // .p12 cifrado (bytea)
  certIv             String?   @map("cert_iv")               // IV hex (12 bytes = 24 chars)
  certAuthTag        String?   @map("cert_auth_tag")         // AuthTag hex (16 bytes)
  certPassEncriptado String?   @map("cert_pass_encriptado")  // passphrase cifrada
  certPassIv         String?   @map("cert_pass_iv")
  certPassAuthTag    String?   @map("cert_pass_auth_tag")
  certSubidoEn       DateTime? @map("cert_subido_en")
  certExpiraEn       DateTime? @map("cert_expira_en")        // extraído del X509

  // Código de Seguridad del Contribuyente (CSC) — proporcionado por DNIT para hash del QR
  // Pruebas: idCsc="0001", csc="ABCD0000000000000000000000000000"
  idCsc          String?  @default("0001") @map("id_csc")
  csc            String?  @map("csc")

  // Webhooks
  webhookUrl     String?  @map("webhook_url")
  webhookSecret  String?  @map("webhook_secret")   // HMAC-SHA256 key (hex 64 chars)
  webhookActivo  Boolean  @default(false) @map("webhook_activo")

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  apiKeys          ApiKey[]
  timbrados        Timbrado[]
  documentos       DocumentoElectronico[]
  eventos          EventoElectronico[]
  auditLogs        AuditLog[]
  secuencias       SecuenciaTimbrado[]
  idempotencia     IdempotencyRecord[]
  webhookDeliveries WebhookDelivery[]

  @@map("tenants")
}

model ApiKey {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  hash      String    @unique
  nombre    String
  activa    Boolean   @default(true)
  isAdmin   Boolean   @default(false) @map("is_admin")
  ultimoUso DateTime? @map("ultimo_uso")
  creadaEn  DateTime  @default(now()) @map("creada_en")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("api_keys")
}

// ─── Timbrado ─────────────────────────────────────────────────────────────────

model Timbrado {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  numero          String
  establecimiento String
  puntoExpedicion String    @map("punto_expedicion")
  tipoDocumento   Int       @map("tipo_documento")
  fechaInicio     DateTime  @map("fecha_inicio")
  fechaFin        DateTime? @map("fecha_fin")
  activo          Boolean   @default(true)
  creadoEn        DateTime  @default(now()) @map("creado_en")

  tenant     Tenant                 @relation(fields: [tenantId], references: [id])
  documentos DocumentoElectronico[]
  secuencia  SecuenciaTimbrado?

  @@unique([tenantId, numero, establecimiento, puntoExpedicion, tipoDocumento])
  @@map("timbrados")
}

model SecuenciaTimbrado {
  timbradoId    String   @id @map("timbrado_id")
  tenantId      String   @map("tenant_id")
  ultimoNumero  Int      @default(0) @map("ultimo_numero")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  timbrado Timbrado @relation(fields: [timbradoId], references: [id])
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  @@map("secuencias_timbrado")
}

// ─── Documentos Electrónicos ─────────────────────────────────────────────────

enum EstadoDE {
  PENDIENTE
  ENVIADO
  APROBADO
  APROBADO_CON_OBSERVACIONES
  RECHAZADO
  CANCELADO
  INUTILIZADO
  EN_PROCESO
  ERROR
}

model DocumentoElectronico {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  timbradoId    String   @map("timbrado_id")
  cdc           String   @unique
  numero        Int

  tipoDocumento Int      @map("tipo_documento")
  tipoEmision   Int      @default(1) @map("tipo_emision")
  estado        EstadoDE @default(PENDIENTE)

  receptorRuc    String? @map("receptor_ruc")
  receptorNombre String  @map("receptor_nombre")

  moneda      String @default("PYG")
  totalBruto  Int    @map("total_bruto")
  totalIva    Int    @map("total_iva")

  xmlFirmado            String? @map("xml_firmado") @db.Text
  xmlRespuesta          String? @map("xml_respuesta") @db.Text
  nroProtocolo          String? @map("nro_protocolo")
  codigoRespuestaSifen  String? @map("codigo_respuesta_sifen")
  mensajeRespuestaSifen String? @map("mensaje_respuesta_sifen")

  fechaEmision    DateTime  @map("fecha_emision")
  fechaAprobacion DateTime? @map("fecha_aprobacion")
  creadoEn        DateTime  @default(now()) @map("creado_en")
  actualizadoEn   DateTime  @updatedAt @map("actualizado_en")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  timbrado  Timbrado  @relation(fields: [timbradoId], references: [id])
  eventos   EventoElectronico[]
  auditLogs AuditLog[]

  @@unique([tenantId, timbradoId, numero])
  @@index([tenantId, estado])
  @@index([tenantId, fechaEmision])
  @@map("documentos_electronicos")
}

// ─── Idempotencia ─────────────────────────────────────────────────────────────

model IdempotencyRecord {
  key          String   @id
  tenantId     String   @map("tenant_id")
  responseBody Json     @map("response_body")
  statusCode   Int      @map("status_code")
  expiresAt    DateTime @map("expires_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([expiresAt])
  @@map("idempotency_records")
}

// ─── Eventos ──────────────────────────────────────────────────────────────────

enum EstadoEvento {
  PENDIENTE
  ENVIADO
  ACEPTADO
  RECHAZADO
  ERROR
}

model EventoElectronico {
  id          String       @id @default(cuid())
  tenantId    String       @map("tenant_id")
  documentoId String?      @map("documento_id")
  tipoEvento  Int          @map("tipo_evento")
  estado      EstadoEvento @default(PENDIENTE)
  motivo      String?

  xmlEvento    String? @map("xml_evento") @db.Text
  xmlRespuesta String? @map("xml_respuesta") @db.Text

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant     Tenant                @relation(fields: [tenantId], references: [id])
  documento  DocumentoElectronico? @relation(fields: [documentoId], references: [id])
  auditLogs  AuditLog[]

  @@index([tenantId, tipoEvento])
  @@map("eventos_electronicos")
}

// ─── Webhooks ─────────────────────────────────────────────────────────────────

enum WebhookEstado {
  PENDIENTE
  ENTREGADO
  FALLIDO
}

model WebhookDelivery {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  evento      String        // "de.aprobado", "lote.completado", etc.
  payload     Json
  estado      WebhookEstado @default(PENDIENTE)
  intentos    Int           @default(0)
  ultimoError String?       @map("ultimo_error")
  statusCode  Int?          @map("status_code")
  creadoEn    DateTime      @default(now()) @map("creado_en")
  entregadoEn DateTime?     @map("entregado_en")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, creadoEn])
  @@index([estado])
  @@map("webhook_deliveries")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

enum TipoAccion {
  EMISION_DE
  ENVIO_LOTE
  CONSULTA_CDC
  CONSULTA_LOTE
  CONSULTA_RUC
  ENVIO_EVENTO
  CANCELACION
  INUTILIZACION
}

model AuditLog {
  id          String     @id @default(cuid())
  tenantId    String     @map("tenant_id")
  accion      TipoAccion
  documentoId String?    @map("documento_id")
  eventoId    String?    @map("evento_id")
  exitoso     Boolean
  mensaje     String?
  detalles    Json?
  ip          String?
  userAgent   String?    @map("user_agent")
  durationMs  Int?       @map("duration_ms")
  creadoEn    DateTime   @default(now()) @map("creado_en")

  tenant     Tenant                 @relation(fields: [tenantId], references: [id])
  documento  DocumentoElectronico?  @relation(fields: [documentoId], references: [id])
  evento     EventoElectronico?     @relation(fields: [eventoId], references: [id])

  @@index([tenantId, accion])
  @@index([tenantId, creadoEn])
  @@map("audit_logs")
}
