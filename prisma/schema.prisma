generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant ──────────────────────────────────────────────────────────────

model Tenant {
  id            String   @id @default(cuid())
  nombre        String
  ruc           String   @unique
  dvRuc         String   @map("dv_ruc")
  activo        Boolean  @default(true)
  rateLimitMax  Int?     @map("rate_limit_max")   // override del global por tenant
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  apiKeys      ApiKey[]
  timbrados    Timbrado[]
  documentos   DocumentoElectronico[]
  eventos      EventoElectronico[]
  auditLogs    AuditLog[]
  secuencias   SecuenciaTimbrado[]
  idempotencia IdempotencyRecord[]

  @@map("tenants")
}

model ApiKey {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  hash      String    @unique
  nombre    String
  activa    Boolean   @default(true)
  isAdmin   Boolean   @default(false) @map("is_admin")  // acceso a rutas /admin
  ultimoUso DateTime? @map("ultimo_uso")
  creadaEn  DateTime  @default(now()) @map("creada_en")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("api_keys")
}

// ─── Timbrado ─────────────────────────────────────────────────────────────────

model Timbrado {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  numero          String    // 8 dígitos
  establecimiento String    // 3 dígitos
  puntoExpedicion String    @map("punto_expedicion")
  tipoDocumento   Int       @map("tipo_documento")
  fechaInicio     DateTime  @map("fecha_inicio")
  fechaFin        DateTime? @map("fecha_fin")
  activo          Boolean   @default(true)
  creadoEn        DateTime  @default(now()) @map("creado_en")

  tenant     Tenant                 @relation(fields: [tenantId], references: [id])
  documentos DocumentoElectronico[]
  secuencia  SecuenciaTimbrado?

  @@unique([tenantId, numero, establecimiento, puntoExpedicion, tipoDocumento])
  @@map("timbrados")
}

// Secuencia atómica por timbrado — evita race conditions en numeración correlativa
model SecuenciaTimbrado {
  timbradoId    String   @id @map("timbrado_id")
  tenantId      String   @map("tenant_id")
  ultimoNumero  Int      @default(0) @map("ultimo_numero")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  timbrado Timbrado @relation(fields: [timbradoId], references: [id])
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  @@map("secuencias_timbrado")
}

// ─── Documentos Electrónicos ─────────────────────────────────────────────────

enum EstadoDE {
  PENDIENTE
  ENVIADO
  APROBADO
  APROBADO_CON_OBSERVACIONES
  RECHAZADO
  CANCELADO
  INUTILIZADO
  EN_PROCESO  // lote async — SIFEN recibió pero aún no procesó
  ERROR
}

model DocumentoElectronico {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  timbradoId    String   @map("timbrado_id")
  cdc           String   @unique
  numero        Int

  tipoDocumento Int      @map("tipo_documento")
  tipoEmision   Int      @default(1) @map("tipo_emision")
  estado        EstadoDE @default(PENDIENTE)

  // Receptor
  receptorRuc    String? @map("receptor_ruc")
  receptorNombre String  @map("receptor_nombre")

  // Totales (en Guaraníes enteros)
  moneda      String @default("PYG")
  totalBruto  Int    @map("total_bruto")
  totalIva    Int    @map("total_iva")

  // XML y respuesta SIFEN
  xmlFirmado            String? @map("xml_firmado") @db.Text
  xmlRespuesta          String? @map("xml_respuesta") @db.Text
  nroProtocolo          String? @map("nro_protocolo")
  codigoRespuestaSifen  String? @map("codigo_respuesta_sifen")   // dCodRes de SIFEN
  mensajeRespuestaSifen String? @map("mensaje_respuesta_sifen")  // dMsgRes de SIFEN

  // Fechas
  fechaEmision    DateTime  @map("fecha_emision")
  fechaAprobacion DateTime? @map("fecha_aprobacion")
  creadoEn        DateTime  @default(now()) @map("creado_en")
  actualizadoEn   DateTime  @updatedAt @map("actualizado_en")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  timbrado  Timbrado  @relation(fields: [timbradoId], references: [id])
  eventos   EventoElectronico[]
  auditLogs AuditLog[]

  @@unique([tenantId, timbradoId, numero])  // protección contra duplicados a nivel DB
  @@index([tenantId, estado])
  @@index([tenantId, fechaEmision])
  @@map("documentos_electronicos")
}

// ─── Idempotencia ─────────────────────────────────────────────────────────────

// Registro para X-Idempotency-Key — evita doble emisión por retry de red
model IdempotencyRecord {
  key          String   @id                        // X-Idempotency-Key del cliente
  tenantId     String   @map("tenant_id")
  responseBody Json     @map("response_body")       // respuesta original serializada
  statusCode   Int      @map("status_code")
  expiresAt    DateTime @map("expires_at")          // TTL: 24 horas

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([expiresAt])
  @@map("idempotency_records")
}

// ─── Eventos ──────────────────────────────────────────────────────────────────

enum EstadoEvento {
  PENDIENTE
  ENVIADO
  ACEPTADO
  RECHAZADO
  ERROR
}

model EventoElectronico {
  id          String       @id @default(cuid())
  tenantId    String       @map("tenant_id")
  documentoId String?      @map("documento_id")
  tipoEvento  Int          @map("tipo_evento")
  estado      EstadoEvento @default(PENDIENTE)
  motivo      String?

  xmlEvento    String? @map("xml_evento") @db.Text
  xmlRespuesta String? @map("xml_respuesta") @db.Text

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant     Tenant                @relation(fields: [tenantId], references: [id])
  documento  DocumentoElectronico? @relation(fields: [documentoId], references: [id])
  auditLogs  AuditLog[]

  @@index([tenantId, tipoEvento])
  @@map("eventos_electronicos")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

enum TipoAccion {
  EMISION_DE
  ENVIO_LOTE
  CONSULTA_CDC
  CONSULTA_RUC
  ENVIO_EVENTO
  CANCELACION
  INUTILIZACION
}

model AuditLog {
  id          String     @id @default(cuid())
  tenantId    String     @map("tenant_id")
  accion      TipoAccion
  documentoId String?    @map("documento_id")
  eventoId    String?    @map("evento_id")
  exitoso     Boolean
  mensaje     String?
  detalles    Json?
  ip          String?
  userAgent   String?    @map("user_agent")
  durationMs  Int?       @map("duration_ms")
  creadoEn    DateTime   @default(now()) @map("creado_en")

  tenant     Tenant                 @relation(fields: [tenantId], references: [id])
  documento  DocumentoElectronico?  @relation(fields: [documentoId], references: [id])
  evento     EventoElectronico?     @relation(fields: [eventoId], references: [id])

  @@index([tenantId, accion])
  @@index([tenantId, creadoEn])
  @@map("audit_logs")
}
