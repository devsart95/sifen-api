{
  "name": "sifen-api",
  "version": "0.3.0",
  "description": "REST API gateway para SIFEN Paraguay — facturación electrónica sin SOAP",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "DevSar <sartoriodevr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/devsart95/sifen-api"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && tsup",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.650.0",
    "@aws-sdk/s3-request-presigner": "^3.650.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/client": "^5.22.0",
    "@xmldom/xmldom": "^0.9.5",
    "axios": "^1.7.7",
    "bullmq": "^5.13.2",
    "fast-xml-parser": "^4.5.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^5.0.0",
    "node-forge": "^1.3.1",
    "puppeteer": "^23.5.3",
    "xmlbuilder2": "^3.1.1",
    "pino": "^9.4.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/node-forge": "^1.3.11",
    "@types/pino": "^7.0.5",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0",
    "vitest": "^2.1.1"
  }
}
